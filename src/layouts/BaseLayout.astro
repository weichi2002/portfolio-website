---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Personal portfolio — Full-Stack developer, systems builder, creative technologist." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050a12" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}image.png`} />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-text font-sans">
    <slot />
  </body>
</html>
