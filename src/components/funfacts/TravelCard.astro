    { name: "Vermont", lat: 44.476, lng: -73.212 },
    { name: "Toronto", lat: 43.653, lng: -79.383 },
    { name: "Panama", lat: 8.982, lng: -79.520 },
    { name: "Munich", lat: 48.135, lng: 11.582 },
    { name: "Vienna", lat: 48.208, lng: 16.374 },
    { name: "Budapest", lat: 47.498, lng: 19.040 },
    { name: "Bratislava", lat: 48.149, lng: 17.108 },
    { name: "Prague", lat: 50.076, lng: 14.438 },
    { name: "Seoul", lat: 37.567, lng: 126.978 },
    { name: "Japan", lat: 35.676, lng: 139.650 },
  ];

  function initGlobe() {
    if (globeInstance) return;

    const container = document.getElementById('travel-globe');
    if (!container) return;

    const size = container.offsetWidth;

    globeInstance = Globe()
      .globeImageUrl('//unpkg.com/three-globe/example/img/earth-blue-marble.jpg')
      .bumpImageUrl('//unpkg.com/three-globe/example/img/earth-topology.png')
      .backgroundColor('rgba(0,0,0,0)')
      .width(size)
      .height(size)
      .pointsData(locations)
      .pointLat('lat')
      .pointLng('lng')
      .pointColor(() => '#ef4444')
      .pointAltitude(0.01)
      .pointRadius(0.4)
      .pointLabel('name')
      (container);

    // Auto-rotation via OrbitControls
    const controls = globeInstance.controls();
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.5;
    controls.enableZoom = true;
    controls.minDistance = 120;
    controls.maxDistance = 500;

    // Point camera at Taiwan initially
    globeInstance.pointOfView({ lat: 25, lng: 121, altitude: 2.5 }, 0);
  }

  document.querySelector('[data-modal="travel"]')
    ?.addEventListener('card:open', initGlobe);
</script>
