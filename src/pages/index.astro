---
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutSection from "../components/AboutSection.astro";
import Contact from "../components/Contact.astro";
import Projects from "../components/Projects.astro";
---

<BaseLayout title="Portfolio" description="Full-Stack developer, systems builder, and creative technologist.">
  <!-- Sticky nav bar -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo" aria-label="Home">
        <img src={`${import.meta.env.BASE_URL}iron_elo.png`} alt="Iron Rank" class="nav-rank-icon" />
        <span class="logo-name">Kreachydud#NA1</span>
      </a>

      <nav class="header-nav" aria-label="Page sections">
        <a href="#about" class="nav-link">About</a>
        <a href="#projects" class="nav-link">Projects</a>
      </nav>

      <div class="header-contact">
        <Contact />
      </div>

      <!-- Mobile menu toggle -->
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile drawer -->
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <nav class="mobile-nav">
        <a href="#about" class="mobile-nav-link">About</a>
        <a href="#projects" class="mobile-nav-link">Projects</a>
        <div class="mobile-contact">
          <Contact />
        </div>
      </nav>
    </div>
  </header>

  <main>
    <!-- Section 1: About Me (default homepage) -->
    <section id="about">
      <AboutSection />
    </section>

    <!-- Section divider -->
    <div class="section-divider" aria-hidden="true">
      <div class="divider-line"></div>
      <div class="divider-diamond"></div>
      <div class="divider-line"></div>
    </div>

    <!-- Section 2: Projects -->
    <section id="projects" class="projects-section">
      <div class="container-responsive">
        <Projects />
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-text">not jungle diff · &copy; {new Date().getFullYear()}</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ─── Site Header ─── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(5, 10, 18, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(200, 155, 60, 0.1);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.875rem 1rem;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .header-inner { padding: 0.875rem 1.5rem; }
  }

  @media (min-width: 1024px) {
    .header-inner { padding: 0.875rem 2.5rem; }
  }

  /* Logo */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.05em;
    color: rgba(240, 230, 211, 0.9);
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .site-logo:hover { color: #c89b3c; }
  .nav-rank-icon {
    height: 2.5rem;
    width: auto;
    object-fit: contain;
  }

  /* Desktop nav */
  .header-nav {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .header-nav { display: flex; }
  }

  .nav-link {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(139, 139, 158, 0.9);
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-link:hover {
    color: rgba(200, 155, 60, 0.9);
    background: rgba(200, 155, 60, 0.06);
  }

  /* Desktop contact */
  .header-contact {
    display: none;
  }
  @media (min-width: 768px) {
    .header-contact { display: block; }
  }

  /* Mobile menu button */
  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 4px;
    transition: background 0.2s;
  }
  .mobile-menu-btn:hover { background: rgba(200, 155, 60, 0.06); }
  .mobile-menu-btn span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: rgba(200, 155, 60, 0.7);
    transition: transform 0.25s ease, opacity 0.25s ease;
    border-radius: 2px;
  }
  .mobile-menu-btn.open span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .mobile-menu-btn.open span:nth-child(2) { opacity: 0; }
  .mobile-menu-btn.open span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  @media (min-width: 768px) {
    .mobile-menu-btn { display: none; }
  }

  /* Mobile drawer */
  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
    border-top: 1px solid transparent;
  }
  .mobile-menu.open {
    max-height: 300px;
    border-top-color: rgba(200, 155, 60, 0.1);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    gap: 0.25rem;
  }

  .mobile-nav-link {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(139, 139, 158, 0.9);
    padding: 0.6rem 0.75rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
  }
  .mobile-nav-link:hover {
    color: rgba(200, 155, 60, 0.9);
    background: rgba(200, 155, 60, 0.06);
  }

  .mobile-contact {
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(200, 155, 60, 0.1);
  }

  /* ─── Section divider ─── */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(200, 155, 60, 0.25), transparent);
  }

  .divider-diamond {
    width: 6px;
    height: 6px;
    background: rgba(200, 155, 60, 0.5);
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  /* ─── Projects section ─── */
  .projects-section {
    padding: 5rem 0 4rem;
  }

  /* ─── Footer ─── */
  .site-footer {
    border-top: 1px solid rgba(200, 155, 60, 0.1);
    padding: 2rem 0;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .footer-text {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(139, 139, 158, 0.5);
  }
</style>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = btn.classList.toggle('open');
    menu?.classList.toggle('open', isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close mobile menu when a nav link is clicked
  menu?.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      btn?.classList.remove('open');
      menu?.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
    });
  });

  // Shrink header on scroll
  const header = document.querySelector('.site-header') as HTMLElement;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      header?.style.setProperty('background', 'rgba(5, 10, 18, 0.97)');
      header?.style.setProperty('border-bottom-color', 'rgba(200, 155, 60, 0.18)');
    } else {
      header?.style.setProperty('background', 'rgba(5, 10, 18, 0.85)');
      header?.style.setProperty('border-bottom-color', 'rgba(200, 155, 60, 0.1)');
    }
  }, { passive: true });
</script>
