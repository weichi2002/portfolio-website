---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FunFacts from '../components/FunFacts.astro';
import Contact from '../components/Contact.astro';
import ScrollArrow from '../components/ScrollArrow.astro';
import Projects from '../components/Projects.astro';
---
<BaseLayout title="Portfolio">
  <main>
    <section class="relative min-h-screen flex flex-col items-center justify-start pt-24 md:pt-32 overflow-hidden">
      <Hero />
      <div class="mt-16 w-full relative z-10">
        <FunFacts />
      </div>
      <div class="mt-12 w-full relative z-10">
        <Contact />
      </div>
      <div class="mt-auto pb-8">
        <ScrollArrow />
      </div>
    </section>
    <section id="projects" class="min-h-screen py-20 md:py-32 px-6 bg-bg-soft">
      <div class="max-w-4xl mx-auto">
        <Projects />
      </div>
    </section>
  </main>
</BaseLayout>
